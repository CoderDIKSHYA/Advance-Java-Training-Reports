package com.capg.springboot.controller;

package com.ust.bs.book.controller;

import org.springframework.web.bind.annotation.*;
import org.springframework.web.client.RestTemplate;

import com.ust.bs.book.dto.Book;
import com.ust.bs.book.dto.Rating;
import com.ust.bs.book.dto.BookDepo;

@RestController
@RequestMapping("/bookinfo")
public class BookDepoController {

    @GetMapping("/{id}")
    public BookDepo getBookInfo(@PathVariable int id) {

        RestTemplate restTemplate = new RestTemplate();

        Book book = restTemplate.getForObject(
                "http://localhost:8081/book/" + id,
                Book.class);

        Rating rating = restTemplate.getForObject(
                "http://localhost:8082/rating/" + id,
                Rating.class);

        BookDepo info = new BookDepo();
        info.setBookId(book.getBookId());
        info.setBookName(book.getBookName());
        info.setBookRating(rating.getBookRating());

        return info;
    }
}